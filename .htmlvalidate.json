{
  "$schema": "https://html-validate.org/schemas/config.json",
  "extends": ["html-validate:recommended"],
  "rules": {
    "void-style": "off",
    "attribute-boolean-style": "off",
    "no-inline-style": "off",
    "long-title": "off",
    "no-implicit-button-type": "off",
    "no-trailing-whitespace": "off",
    "no-raw-characters": "warn"
  }
}
